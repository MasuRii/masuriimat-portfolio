---
import '@/styles/global.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
// JetBrains Mono font faces declared in global.css (self-hosted from public/files/)
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { CommandPalette } from '@/components/CommandPalette';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isHomePage?: boolean;
}

const {
  title,
  description = 'I build the invisible infrastructure — AI middleware, developer tools, and real products — that makes powerful technology work for real people.',
  ogImage = '/og-default.svg',
  isHomePage = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'MasuRii';

// Full-width OG image URL (required for twitter:card summary_large_image)
const ogImageURL = new URL(ogImage, Astro.site).toString();

// Confirmed social links
import { socialLinks } from '@/data/projects';

// JSON-LD: Person schema (all pages)
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Math Lee Lagod Biacolo',
  alternateName: 'MasuRii',
  url: 'https://masurii.dev',
  sameAs: socialLinks.map(link => link.url),
  jobTitle: 'Developer',
  knowsAbout: ['AI Infrastructure', 'Developer Tools', 'TypeScript', 'Python', 'Rust'],
};

// JSON-LD: WebSite schema (home page only)
const webSiteSchema = isHomePage ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: 'https://masurii.dev',
  description: description,
  author: {
    '@type': 'Person',
    name: 'Math Lee Lagod Biacolo',
  },
} : null;

// Combine all schemas for this page
const schemas = [personSchema, webSiteSchema].filter(Boolean);

const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="MasuRii" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content={isHomePage ? 'website' : 'article'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    {!isHomePage && <meta property="article:author" content="MasuRii" />}
    {!isHomePage && <meta property="article:section" content="Project" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD -->
    {schemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Mobile browser theme color (terracotta accent, matches dark mode) -->
    <meta name="theme-color" content="#0C0C0C" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0C0C0C" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FAFAFA" />

    <!-- Theme initialization: dark-first, prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        // Default to dark; only switch to light if explicitly stored or OS prefers light
        var theme;
        if (stored) {
          theme = stored;
        } else if (prefersLight) {
          theme = 'light';
        } else {
          theme = 'dark';
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg text-text flex flex-col">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>
    <Footer />
    <CommandPalette client:only="react" />
  </body>
</html>