---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { ProjectScreenshot } from '@/data/projects';

interface Props {
  title: string;
  description: string;
  projectUrl: string;
  stars?: number;
  forks?: number;
  techTags?: string[];
  liveUrl?: string;
  screenshots?: ProjectScreenshot[];
}

const {
  title,
  description,
  projectUrl,
  stars,
  forks,
  techTags = [],
  liveUrl,
  screenshots = [],
} = Astro.props;

const primaryScreenshot = screenshots[0] || null;

// JSON-LD: SoftwareSourceCode for project pages
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: title,
  description: description,
  author: {
    '@type': 'Person',
    name: 'MasuRii',
    url: 'https://masurii.dev',
  },
  codeRepository: projectUrl,
  programmingLanguage: techTags.length > 0 ? techTags[0] : undefined,
  ...(stars && stars >= 1 ? { interactionStatistic: {
    '@type': 'InteractionCounter',
    interactionType: 'https://schema.org/LikeAction',
    userInteractionCount: stars,
  } } : {}),
  ...(liveUrl ? { url: liveUrl } : {}),
};
---

<BaseLayout title={`${title} — MasuRii`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <article class="py-16 md:py-24" aria-labelledby="case-study-heading">
    <div class="max-w-content mx-auto px-4 md:px-12">
      <!-- Back link — TUI style -->
      <a
        href="/projects"
        class="inline-flex items-center gap-2 text-sm font-mono text-text-muted hover:text-accent transition-colors mb-8 min-h-[44px]"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        ../projects
      </a>

      <!-- TUI prompt + title -->
      <p class="tui-heading mb-2" aria-hidden="true">
        <span class="text-accent">$</span> cat <span class="text-path">{title.toLowerCase().replace(/\s/g, '-')}.md</span>
      </p>
      <h1 id="case-study-heading" class="text-4xl md:text-5xl font-display font-bold text-text mb-3">
        {title}
      </h1>
      <p class="text-lg text-text-muted mb-6">
        {description}
      </p>

      <!-- Screenshot, if available -->
      {primaryScreenshot && (
        <div class="tui-screenshot mb-8">
          <img
            src={primaryScreenshot.url}
            alt={primaryScreenshot.alt}
            loading="lazy"
            decoding="async"
            width={primaryScreenshot.width}
            height={primaryScreenshot.height}
          />
        </div>
      )}

      <!-- Metadata status line -->
      <div class="tui-statusline mb-8 pb-4">
        {stars && stars >= 1 && (
          <span class="tui-statusline-item">
            <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {stars}★ {forks && forks > 1 && `· ${forks} forks`}
          </span>
        )}
        <a
          href={projectUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-accent hover:underline"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          source
        </a>
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-green hover:underline"
            style="color: var(--color-green);"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" />
            </svg>
            live demo
          </a>
        )}

        <!-- Tech tags -->
        <div class="flex-1" />
        <div class="flex flex-wrap gap-1.5" role="list" aria-label="Technologies">
          {techTags.map(tag => (
            <span class="tui-tag" role="listitem">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Case study content -->
      <div class="prose-tui">
        <slot />
      </div>

      <!-- Bottom links -->
      <div class="mt-16 pt-6 border-t border-border flex flex-wrap gap-6">
        <a
          href={projectUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-mono text-accent hover:underline min-h-[44px]"
        >
          <span class="text-text-dim">$</span> open source →
        </a>
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-sm font-mono text-text-muted hover:text-accent transition-colors min-h-[44px]"
        >
          ← ../projects
        </a>
      </div>
    </div>
  </article>
</BaseLayout>