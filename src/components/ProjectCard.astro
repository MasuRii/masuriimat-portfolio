---
import type { ProjectScreenshot } from '@/data/projects';
import type { ProjectTier } from '@/data/projects';
import { tierLabels } from '@/data/projects';

interface Props {
  href: string;
  title: string;
  tagline: string;
  language: string;
  stars?: number;
  forks?: number;
  topics?: string[];
  demo?: string;
  screenshots?: ProjectScreenshot[];
  tier?: ProjectTier;
  index: number;
}

const {
  href,
  title,
  tagline,
  language,
  stars = 0,
  forks = 0,
  topics = [],
  demo,
  screenshots = [],
  tier,
  index,
} = Astro.props;

// Use first screenshot as thumbnail, if available
const primaryScreenshot = screenshots[0] || null;

// Tier display config
const tierConfig: Record<ProjectTier, { label: string; prefix: string }> = {
  flagship: { label: 'Flagship', prefix: '##' },
  notable: { label: 'Notable', prefix: ' #' },
  extension: { label: 'Extension', prefix: '  ·' },
};

const displayTier = tier ? tierConfig[tier] : null;
---

<article
  class="group py-6 md:py-8 border-b border-border last:border-b-0 transition-colors duration-150 hover:bg-surface/30 rounded-lg px-3 -mx-3 stagger-card"
  style={`transition-delay: ${index * 60}ms;`}
  role="article"
  data-tier={tier || ''}
>
  <div class="flex flex-col md:flex-row md:items-start gap-4">
    <!-- Left: Project info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-baseline gap-3 flex-wrap">
        <h3 class="font-display font-semibold text-lg md:text-xl text-text group-hover:text-accent transition-colors duration-150">
          {title}
        </h3>

        <!-- Status badges -->
        <div class="flex items-center gap-2 flex-wrap">
          {displayTier && (
            <span class={`tui-badge--${tier}`} title={`${displayTier.label} project`}>
              {tier === 'flagship' && (
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              )}
              {displayTier.label}
            </span>
          )}
          {stars >= 5 && (
            <span class="tui-badge tui-badge--stars" aria-label={`${stars} stars on GitHub`}>
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {stars}
            </span>
          )}
          {demo && (
            <a
              href={demo}
              target="_blank"
              rel="noopener noreferrer"
              class="tui-badge tui-badge--live hover:opacity-80 transition-opacity"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-green-400" aria-hidden="true"></span>
              live
            </a>
          )}
          {!demo && stars >= 1 && (
            <span class="tui-badge" style="background: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);">
              {language}
            </span>
          )}
        </div>
      </div>

      <p class="mt-2 text-text-muted leading-relaxed">
        {tagline}
      </p>

      <!-- Tech tags -->
      <div class="mt-3 flex flex-wrap gap-1.5" role="list" aria-label="Technologies used">
        {topics.slice(0, 5).map(topic => (
          <span class="tui-tag" role="listitem">
            {topic}
          </span>
        ))}
      </div>
    </div>

    <!-- Right: Screenshot thumbnail / CTA -->
    <div class="flex-shrink-0 self-start md:self-center flex flex-col items-end gap-2">
      {primaryScreenshot && (
        <div class="tui-screenshot max-w-[240px] md:max-w-[280px]">
          <img
            src={primaryScreenshot.url}
            alt={primaryScreenshot.alt}
            loading="lazy"
            decoding="async"
            width={primaryScreenshot.width}
            height={primaryScreenshot.height}
          />
        </div>
      )}
      <a
        href={href}
        class="inline-flex items-center gap-1.5 text-sm font-mono text-accent hover:underline min-h-[44px] min-w-[44px] justify-center"
      >
        view
        <svg class="w-3.5 h-3.5 transition-transform duration-150 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>