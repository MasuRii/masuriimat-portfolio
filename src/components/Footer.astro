---
// Footer — TUI-styled status bar
import { socialLinks } from '@/data/projects';
const year = new Date().getFullYear();
---

<footer class="border-t border-border" role="contentinfo" style="background-color: var(--color-surface);">
  <div class="max-w-showcase mx-auto px-5 sm:px-8 md:px-12 py-10 md:py-14">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Brand prompt -->
      <div>
        <a href="/" class="font-mono text-sm text-accent hover:text-accent-hover transition-colors">
          <span class="text-text-dim">$</span> cd ~<span class="text-text-dim">/</span>masurii
        </a>
        <p class="text-xs text-text-dim mt-2 max-w-xs font-mono">
          Building invisible infrastructure at the intersection of AI, developer tools, and real products.
        </p>
      </div>

      <!-- Quick links -->
      <nav aria-label="Footer navigation" class="flex flex-col gap-2">
        <a href="/" class="font-mono text-xs text-text-muted hover:text-accent transition-colors"><span class="text-text-dim">./</span>home</a>
        <a href="/projects" class="font-mono text-xs text-text-muted hover:text-accent transition-colors"><span class="text-text-dim">./</span>projects</a>
        <a href="/#about" class="font-mono text-xs text-text-muted hover:text-accent transition-colors"><span class="text-text-dim">./</span>about</a>
        <a href="/#contact" class="font-mono text-xs text-text-muted hover:text-accent transition-colors"><span class="text-text-dim">./</span>contact</a>
      </nav>

      <!-- External links — from centralized data -->
      <div class="flex flex-col gap-2">
        {socialLinks.map(link => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-mono text-xs text-text-muted hover:text-accent transition-colors"
          >
            {link.icon === 'github' && (
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {link.icon === 'linkedin' && (
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {link.icon === 'facebook' && (
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            )}
            {link.icon === 'greasyfork' && (
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 8l-4 4 4 4" />
              </svg>
            )}
            {link.icon === 'org' && (
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            )}
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom bar — TUI status line -->
    <div class="mt-10 pt-6 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-3">
      <div class="flex items-center gap-4">
        <a href="https://rxresu.me/masurii/masurii" target="_blank" rel="noopener noreferrer" class="text-[11px] font-mono text-text-muted hover:text-accent transition-colors inline-flex items-center gap-1.5 min-h-[36px]">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          résumé/cv
        </a>
      </div>
      <p class="text-[11px] font-mono text-text-dim">
        &copy; {year} Math Lee Lagod Biacolo. Cebu, PH.
      </p>
    </div>
  </div>
</footer>